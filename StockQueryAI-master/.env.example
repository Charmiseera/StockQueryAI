# Backend Environment Configuration

# ========================================
# REQUIRED - API Keys
# ========================================

# Nebius API Key for LLM access
# Get from: https://console.nebius.cloud/
# Without this, the query endpoint will return 503 error
NEBIUS_API_KEY=your-nebius-api-key-here

# ========================================
# REQUIRED - Security
# ========================================

# JWT Secret Key for token signing
# Use a strong, random string (min 32 characters)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# NEVER use default in production!
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ========================================
# OPTIONAL - Text-to-Speech (ElevenLabs)
# ========================================

# ElevenLabs API Key for TTS
# Get from: https://elevenlabs.io/
# Leave blank to disable TTS feature
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# ElevenLabs Voice ID
# Choose from: https://elevenlabs.io/docs/voices
# Popular: 21m00Tcm4TlvDq8ikWAM (Rachel), pNInz6obpgDQGcFmaJgB (Adam)
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ========================================
# OPTIONAL - Advanced Configuration
# ========================================

# Port for FastAPI server (default: 8000)
# SERVER_PORT=8000

# Port for MCP Server (default: 8001)
# MCP_PORT=8001

# Database path (default: mcp_server/inventory.db)
# DB_PATH=./mcp_server/inventory.db
